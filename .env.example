# ─── .env.example — PLANTILLA (sin valores reales) ──────────
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el .env real al repositorio.

SECRET_KEY=cambia-esto-por-una-clave-larga-y-random

# False en producción
DEBUG=False

# IPs/dominios del servidor
ALLOWED_HOSTS=tudominio.cl,www.tudominio.cl,10.0.100.25

# CORS — False en producción
CORS_ALLOW_ALL_ORIGINS=False

# Correo SMTP
EMAIL_HOST_USER=correo@gmail.com
EMAIL_HOST_PASSWORD=app_password_aqui
RESERVAS_ADMIN_EMAIL=responsable@tudominio.cl
