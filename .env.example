# ==============================================================================
# SGAF - ARCHIVO DE CONFIGURACIÓN DE EJEMPLO (.env.example)
# ==============================================================================
# Instrucciones: 
# 1. Copia este archivo como '.env'
# 2. Rellena los valores reales de acuerdo a tu entorno (Producción/Desarrollo)
# ==============================================================================

# --- SEGURIDAD Y DJANGO ---
SECRET_KEY=tu_clave_secreta_aqui
DEBUG=False
ALLOWED_HOSTS=10.0.100.119,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://10.0.100.119,http://localhost:5173

# --- BASE DE DATOS (POSTGRESQL) ---
# Nota: En desarrollo local puedes usar SQLite omitiendo estas variables
DB_NAME=sgaf_db
DB_USER=sgaf_user
DB_PASSWORD=tu_password_seguro_aqui
DB_HOST=db
DB_PORT=5432

# --- CONFIGURACIÓN DE CORREO (SMTP) ---
# Nota: Estos valores también pueden ser configurados desde el panel admin
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=soporte.slepiquique@gmail.com
EMAIL_HOST_PASSWORD=tu_password_de_aplicacion_aqui
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=soporte.slepiquique@gmail.com

# --- DOCKER CONFIG ---
BACKEND_PORT=8000
FRONTEND_PORT=5173
NGINX_PORT=8080

# --- LÍMITES Y OTROS ---
EMAIL_DAILY_LIMIT=200
VITE_API_URL=http://localhost:8000/api
